<%
    const tipoStyles = {
        mantencion:     { chip: 'bg-amber-500/15 text-amber-200 border-l-2 border-amber-400', dot: 'bg-amber-400', tag: 'bg-amber-500/15 text-amber-300 border border-amber-500/30' },
        ticket:         { chip: 'bg-blue-500/15 text-blue-200 border-l-2 border-blue-400', dot: 'bg-blue-400', tag: 'bg-blue-500/15 text-blue-300 border border-blue-500/30' },
        visita_tecnica: { chip: 'bg-violet-500/15 text-violet-200 border-l-2 border-violet-400', dot: 'bg-violet-400', tag: 'bg-violet-500/15 text-violet-300 border border-violet-500/30' },
        garantia:       { chip: 'bg-emerald-500/15 text-emerald-200 border-l-2 border-emerald-400', dot: 'bg-emerald-400', tag: 'bg-emerald-500/15 text-emerald-300 border border-emerald-500/30' },
        otro:           { chip: 'bg-slate-500/15 text-slate-200 border-l-2 border-slate-400', dot: 'bg-slate-400', tag: 'bg-slate-500/15 text-slate-300 border border-slate-500/30' }
    };
    const defaultTipoStyle = { chip: 'bg-sky-500/15 text-sky-200 border-l-2 border-sky-400', dot: 'bg-sky-400', tag: 'bg-sky-500/15 text-sky-300 border border-sky-500/30' };
%>

<style>
    .custom-scroll::-webkit-scrollbar { width: 5px; }
    .custom-scroll::-webkit-scrollbar-track { background: transparent; }
    .custom-scroll::-webkit-scrollbar-thumb { background: rgba(71,85,105,.7); border-radius: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb:hover { background: rgba(100,116,139,1); }
    .cal-day { transition: transform .15s ease, box-shadow .15s ease, background-color .15s ease, border-color .15s ease; }
    .cal-day:hover { transform: translateY(-2px); box-shadow: 0 10px 25px -12px rgba(0,0,0,.6); }
    .cal-chip { transition: background-color .15s ease, transform .12s ease; }
    .cal-chip:hover { transform: translateX(1px); }
</style>

<div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
            <div class="hidden sm:flex h-12 w-12 rounded-2xl bg-gradient-to-br from-orange-500/20 to-orange-600/10 border border-orange-500/30 items-center justify-center text-orange-400">
                <i class="ph ph-calendar-dots text-2xl"></i>
            </div>
            <div>
                <h1 class="text-3xl font-bold text-white tracking-tight">Calendario</h1>
                <p class="text-slate-400 text-sm mt-1">Eventos importantes de la empresa visibles para todos.</p>
            </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto items-stretch md:items-center">
            <div class="inline-flex items-center rounded-xl bg-slate-800/80 border border-slate-700/60 p-1 shadow-sm">
                <a href="/calendario?month=<%= prevMonth %>&year=<%= prevYear %>" title="Mes anterior" class="inline-flex items-center justify-center h-9 w-9 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors">
                    <i class="ph ph-caret-left text-base"></i>
                </a>
                <div class="px-4 text-slate-100 text-sm font-semibold whitespace-nowrap min-w-[9rem] text-center">
                    <%= monthName %> <%= year %>
                </div>
                <a href="/calendario?month=<%= nextMonth %>&year=<%= nextYear %>" title="Mes siguiente" class="inline-flex items-center justify-center h-9 w-9 rounded-lg text-slate-300 hover:bg-slate-700 hover:text-white transition-colors">
                    <i class="ph ph-caret-right text-base"></i>
                </a>
            </div>
            <a href="/calendario" class="inline-flex items-center justify-center px-4 py-2 rounded-xl bg-slate-800/80 border border-slate-700/60 hover:bg-slate-700 text-slate-100 text-sm font-medium transition-colors">
                <i class="ph ph-crosshair mr-1.5"></i>
                Hoy
            </a>
            <button onclick="document.getElementById('new-event-modal').classList.remove('hidden')" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-xl transition-colors flex items-center justify-center text-sm font-medium shadow-lg shadow-blue-500/25">
                <i class="ph ph-plus mr-2 text-base"></i> Nuevo Evento
            </button>
        </div>
    </div>

    <!-- Leyenda de tipos -->
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-5 text-xs text-slate-400">
        <span class="font-medium text-slate-500 uppercase tracking-wide">Tipos:</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span> Mantención</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-blue-400"></span> Ticket</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-violet-400"></span> Visita técnica</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span> Garantía</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-slate-400"></span> Otro</span>
    </div>

    <div class="bg-slate-900/70 border border-slate-800 rounded-2xl shadow-xl p-5 md:p-6 backdrop-blur-sm">
        <div class="md:flex md:items-start md:gap-6">
            <div class="md:flex-1">
                <div class="grid grid-cols-7 gap-2 mb-3">
                    <% weekDaysShort.forEach(function(dia, idx) { %>
                        <div class="text-center text-[11px] font-semibold uppercase tracking-wider pb-1 <%= (idx === 0 || idx === 6) ? 'text-orange-300/70' : 'text-slate-400' %>">
                            <%= dia %>
                        </div>
                    <% }); %>
                </div>
                <div class="grid grid-cols-7 gap-2">
                    <% weeks.forEach(function(week) { %>
                        <% week.forEach(function(day, dayIdx) { %>
                            <% if (!day) { %>
                                <div class="h-28 rounded-xl bg-slate-900/30 border border-dashed border-slate-800/70"></div>
                            <% } else { %>
                                <% const isWeekend = (dayIdx === 0 || dayIdx === 6); %>
                                <div class="cal-day h-28 rounded-xl border flex flex-col p-2 overflow-hidden cursor-pointer <%= day.isToday ? 'border-emerald-500/60 bg-emerald-500/[0.07] ring-1 ring-emerald-500/30' : (day.isPast ? 'border-slate-800/70 bg-slate-950/40 hover:bg-slate-900/60' : (isWeekend ? 'border-slate-800 bg-slate-800/30 hover:bg-slate-800/60' : 'border-slate-800 bg-slate-900/60 hover:bg-slate-800/70')) %>"
                                     onclick="openDayDetails(this)"
                                     data-date="<%= day.dateKey %>">
                                    <div class="flex items-center justify-between mb-1.5">
                                        <span class="inline-flex items-center justify-center text-xs font-semibold <%= day.isToday ? 'h-6 w-6 rounded-full bg-emerald-500 text-slate-900' : (day.isPast ? 'text-slate-500' : (isWeekend ? 'text-orange-200/80' : 'text-slate-200')) %>">
                                            <%= day.day %>
                                        </span>
                                        <% if (day.events && day.events.length > 0) { %>
                                            <span class="inline-flex items-center justify-center min-w-[1.1rem] h-[1.1rem] px-1 rounded-full bg-slate-700/70 text-slate-200 text-[9px] font-semibold">
                                                <%= day.events.length %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <div class="space-y-1 overflow-y-auto pr-1 custom-scroll">
                                        <% if (day.events && day.events.length > 0) { %>
                                            <% day.events.forEach(function(ev) { %>
                                                <% const st = tipoStyles[ev.tipo] || defaultTipoStyle; %>
                                                <div class="cal-chip text-[11px] pl-2 pr-1.5 py-1 rounded-md truncate flex items-center justify-between gap-1 <%= st.chip %>" title="<%= ev.titulo %>">
                                                    <span class="truncate font-medium"><%= ev.titulo %></span>
                                                    <% if (ev.hora_inicio) { %>
                                                        <span class="text-[9px] opacity-70 whitespace-nowrap"><%= ev.hora_inicio.slice(0, 5) %></span>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <div class="text-[10px] text-slate-600 italic">Sin eventos</div>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        <% }); %>
                    <% }); %>
                </div>
            </div>
            <div id="day-summary-panel" class="mt-6 md:mt-0 md:w-72 lg:w-80 bg-slate-900/80 border border-slate-800 rounded-xl p-4 hidden">
                <div class="flex items-center gap-2 mb-2 pb-3 border-b border-slate-800">
                    <div class="h-8 w-8 rounded-lg bg-blue-500/15 border border-blue-500/30 flex items-center justify-center text-blue-300">
                        <i class="ph ph-calendar-check"></i>
                    </div>
                    <div>
                        <p class="text-[10px] uppercase tracking-wide text-slate-500">Eventos del día</p>
                        <h3 id="day-summary-title" class="text-sm font-semibold text-white mt-0.5"></h3>
                    </div>
                </div>
                <div id="day-summary-list" class="mt-3 space-y-2 max-h-64 overflow-y-auto custom-scroll"></div>
            </div>
        </div>
    </div>
</div>

<div id="day-details-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4"
     onclick="if (event.target === this) this.classList.add('hidden')">
    <div class="bg-slate-800 p-6 rounded-2xl w-full max-w-md shadow-2xl border border-slate-700 max-h-[80vh] flex flex-col">
        <div class="flex justify-between items-center mb-4">
            <h3 id="day-details-title" class="text-xl font-bold text-white flex items-center gap-2">
                <i class="ph ph-calendar-blank text-blue-400"></i> Eventos
            </h3>
            <button onclick="document.getElementById('day-details-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
                <i class="ph ph-x text-lg"></i>
            </button>
        </div>
        <div id="day-details-content" class="flex-1 overflow-y-auto space-y-3 custom-scroll pr-2"></div>
        <div class="mt-4 flex justify-end">
            <button type="button" class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-100 text-sm"
                    onclick="document.getElementById('day-details-modal').classList.add('hidden')">
                Cerrar
            </button>
        </div>
    </div>
</div>

<script>
const calendarEventsByDate = {};
const calendarEventsById = {};
const calendarCanEditEvents = true;

const calendarTipoStyles = {
    mantencion:     { border: 'border-l-amber-400',  tag: 'bg-amber-500/15 text-amber-300 border border-amber-500/30',   title: 'text-amber-200' },
    ticket:         { border: 'border-l-blue-400',   tag: 'bg-blue-500/15 text-blue-300 border border-blue-500/30',      title: 'text-blue-200' },
    visita_tecnica: { border: 'border-l-violet-400', tag: 'bg-violet-500/15 text-violet-300 border border-violet-500/30', title: 'text-violet-200' },
    garantia:       { border: 'border-l-emerald-400',tag: 'bg-emerald-500/15 text-emerald-300 border border-emerald-500/30', title: 'text-emerald-200' },
    otro:           { border: 'border-l-slate-400',  tag: 'bg-slate-500/15 text-slate-300 border border-slate-500/30',   title: 'text-slate-200' }
};
const calendarDefaultTipoStyle = { border: 'border-l-sky-400', tag: 'bg-sky-500/15 text-sky-300 border border-sky-500/30', title: 'text-sky-200' };

const calendarOpenTickets = <%- JSON.stringify(typeof openTickets !== 'undefined' ? openTickets : []) %>;
const calendarTicketsByTipo = {};
const calendarTicketsById = {};
calendarOpenTickets.forEach(t => {
    const tipo = t.tipo || 'otros';
    if (!calendarTicketsByTipo[tipo]) calendarTicketsByTipo[tipo] = [];
    calendarTicketsByTipo[tipo].push(t);
    calendarTicketsById[String(t.id)] = t;
});

<% weeks.forEach(function(week) { %>
    <% week.forEach(function(day) { if (day) { %>
        calendarEventsByDate["<%= day.dateKey %>"] = <%- JSON.stringify(day.events || []) %>;
    <% } }); %>
<% }); %>

Object.keys(calendarEventsByDate).forEach(function (key) {
    const list = calendarEventsByDate[key];
    if (Array.isArray(list)) {
        list.forEach(function (ev) {
            if (ev && typeof ev.id !== 'undefined') {
                calendarEventsById[String(ev.id)] = ev;
            }
        });
    }
});

function fillTicketSelect(selectEl, tipo, selectedId) {
    if (!selectEl) return;
    selectEl.innerHTML = '';
    if (!tipo) {
        const opt = document.createElement('option');
        opt.value = '';
        opt.textContent = 'Selecciona tipo primero';
        selectEl.appendChild(opt);
        selectEl.disabled = true;
        return;
    }
    const list = calendarTicketsByTipo[tipo] || [];
    if (!list.length) {
        const opt = document.createElement('option');
        opt.value = '';
        opt.textContent = 'Sin tickets abiertos para este tipo';
        selectEl.appendChild(opt);
        selectEl.disabled = true;
        return;
    }
    selectEl.disabled = false;
    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.textContent = 'Selecciona ticket';
    selectEl.appendChild(placeholder);
    list.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t.id;
        opt.textContent = (t.codigo ? t.codigo + ' - ' : '') + (t.titulo || '');
        if (selectedId && String(selectedId) === String(t.id)) {
            opt.selected = true;
        }
        selectEl.appendChild(opt);
    });
}

document.addEventListener('DOMContentLoaded', function () {
    const newTipo = document.getElementById('new-event-ticket-tipo');
    const newTicket = document.getElementById('new-event-ticket-id');
    if (newTipo && newTicket) {
        newTipo.addEventListener('change', function () {
            fillTicketSelect(newTicket, newTipo.value || '', null);
        });
        fillTicketSelect(newTicket, newTipo.value || '', null);
    }

    const editTipo = document.getElementById('edit-event-ticket-tipo');
    const editTicket = document.getElementById('edit-event-ticket-id');
    if (editTipo && editTicket) {
        editTipo.addEventListener('change', function () {
            const current = editTicket.value || null;
            fillTicketSelect(editTicket, editTipo.value || '', current);
        });
    }
});

function openDayDetails(el) {
    const date = el.getAttribute('data-date');
    const rawEvents = calendarEventsByDate[date];
    let events = Array.isArray(rawEvents) ? rawEvents : [];

    // Usar T00:00:00 para evitar desajustes por zona horaria al crear el objeto Date local
    const dateObj = new Date(date + 'T00:00:00');
    const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'America/Santiago' };
    const dateFormattedRaw = dateObj.toLocaleDateString('es-CL', options);
    const dateFormatted = dateFormattedRaw.charAt(0).toUpperCase() + dateFormattedRaw.slice(1);
    
    // Actualizar panel lateral (day-summary-panel)
    const summaryPanel = document.getElementById('day-summary-panel');
    const summaryTitle = document.getElementById('day-summary-title');
    const summaryList = document.getElementById('day-summary-list');

    if (summaryPanel && summaryTitle && summaryList) {
        summaryPanel.classList.remove('hidden');
        summaryTitle.textContent = dateFormatted;
        summaryList.innerHTML = '';

        if (!events || events.length === 0) {
            summaryList.innerHTML = '<p class="text-slate-400 text-xs text-center py-4">No hay eventos para este día.</p>';
        } else {
            events.forEach(ev => {
                const st = calendarTipoStyles[ev.tipo] || calendarDefaultTipoStyle;
                const item = document.createElement('div');
                item.className = 'bg-slate-900/60 border border-slate-700/70 border-l-4 ' + st.border + ' rounded-lg p-3 transition-colors mb-2 hover:bg-slate-900/90';

                let timeStr = '';
                if (ev.hora_inicio) {
                    timeStr += String(ev.hora_inicio).slice(0, 5);
                    if (ev.hora_fin) {
                        timeStr += ' - ' + String(ev.hora_fin).slice(0, 5);
                    }
                }

                const timeBadgeHtml = timeStr
                    ? '<span class="text-xs text-slate-400 bg-slate-800 px-1.5 py-0.5 rounded whitespace-nowrap">' +
                      timeStr +
                      '</span>'
                    : '';

                const descHtml = ev.descripcion
                    ? '<div class="text-xs text-slate-400 mt-1 whitespace-pre-wrap">' +
                      ev.descripcion +
                      '</div>'
                    : '';

                const tipoHtml = ev.tipo
                    ? '<span class="ml-2 text-[10px] px-1.5 py-0.5 rounded-full uppercase tracking-wide ' + st.tag + '">' +
                      ev.tipo +
                      '</span>'
                    : '';
                
                const creator = ev.creado_por || '?';

                let linksHtml = '';
                if (ev.ticket_id) {
                    linksHtml =
                        '<div class="mt-1 flex flex-wrap items-center gap-1">' +
                            '<span class="inline-flex items-center px-1.5 py-0.5 rounded bg-blue-500/15 text-blue-300 text-[10px] mr-1">Ticket #' +
                            ev.ticket_id +
                            '</span>' +
                        '</div>';
                }
                
                let actionsHtml = '';
                if (calendarCanEditEvents && ev && typeof ev.id !== 'undefined') {
                    actionsHtml =
                        '<div class="mt-2 flex gap-2 justify-end pt-2 border-t border-slate-800/50">' +
                            '<button type="button" class="px-2 py-1 rounded bg-slate-700 hover:bg-slate-600 text-[10px] text-slate-100 transition-colors" onclick="openEditEvent(' + ev.id + ')">Editar</button>' +
                            '<button type="button" class="px-2 py-1 rounded bg-red-900/50 hover:bg-red-800/70 text-[10px] text-red-200 transition-colors" onclick="deleteEvent(' + ev.id + ')">Eliminar</button>' +
                        '</div>';
                }

                item.innerHTML =
                    '<div class="flex justify-between items-start gap-2 mb-1">' +
                        '<div class="flex-1">' +
                            '<div class="flex items-center flex-wrap">' +
                                '<span class="text-sm font-medium ' + st.title + ' mr-1">' + (ev.titulo || '') + '</span>' +
                                tipoHtml +
                            '</div>' +
                        '</div>' +
                        timeBadgeHtml +
                    '</div>' +
                    descHtml +
                    linksHtml +
                    '<div class="text-[10px] text-slate-600 mt-2 text-right italic">' +
                        'Creado por: usuario #' + creator +
                    '</div>' +
                    actionsHtml;

                summaryList.appendChild(item);
            });
        }
    }
}

function openEditEvent(id) {
    if (!calendarCanEditEvents) return;
    const ev = calendarEventsById[String(id)];
    if (!ev) return;

    const fechaValue = (ev.fecha || ev.fecha_inicio || '').slice(0, 10);

    document.getElementById('edit-event-id').value = id;
    document.getElementById('edit-event-titulo').value = ev.titulo || '';
    document.getElementById('edit-event-fecha').value = fechaValue || '';
    document.getElementById('edit-event-hora-inicio').value = ev.hora_inicio ? String(ev.hora_inicio).slice(0, 5) : '';
    document.getElementById('edit-event-hora-fin').value = ev.hora_fin ? String(ev.hora_fin).slice(0, 5) : '';
    document.getElementById('edit-event-descripcion').value = ev.descripcion || '';
    document.getElementById('edit-event-tipo').value = ev.tipo || '';

    const editTipo = document.getElementById('edit-event-ticket-tipo');
    const editTicket = document.getElementById('edit-event-ticket-id');
    if (editTipo && editTicket) {
        const related = ev.ticket_id ? calendarTicketsById[String(ev.ticket_id)] : null;
        const tipoTicket = related && related.tipo ? related.tipo : '';
        editTipo.value = tipoTicket || '';
        fillTicketSelect(editTicket, tipoTicket || '', ev.ticket_id || null);
        if (!related && ev.ticket_id) {
            const opt = document.createElement('option');
            opt.value = ev.ticket_id;
            opt.textContent = 'Ticket #' + ev.ticket_id;
            opt.selected = true;
            editTicket.appendChild(opt);
            editTicket.disabled = false;
        }
    }

    document.getElementById('edit-event-modal').classList.remove('hidden');
}

async function submitEditEvent(e) {
    e.preventDefault();
    if (!calendarCanEditEvents) return;

    const id = document.getElementById('edit-event-id').value;
    if (!id) {
        alert('Error interno: ID del evento no encontrado.');
        return;
    }

    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    try {
        const res = await fetch('/calendario/eventos/' + id, {
            method: 'PATCH',
            headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(data)
        });
        if (res.ok) {
            window.location.reload();
        } else {
            let msg = 'Error ' + res.status;
            try {
                const err = await res.json();
                if (err && err.error) msg += ': ' + err.error;
            } catch (_) {
                msg += ': Error inesperado del servidor (posiblemente HTML)';
            }
            alert(msg);
        }
    } catch (err) {
        console.error(err);
        alert('Error de conexión: ' + err.message);
    }
}

async function deleteEvent(id) {
    if (!calendarCanEditEvents) return;
    const confirmed = confirm('¿Seguro que deseas eliminar este evento? Esta acción no se puede deshacer.');
    if (!confirmed) return;

    try {
        const res = await fetch('/calendario/eventos/' + id, {
            method: 'DELETE',
            headers: {
                'Accept': 'application/json'
            }
        });
        if (res.ok) {
            window.location.reload();
        } else {
            let msg = 'Error ' + res.status;
            try {
                const err = await res.json();
                if (err && err.error) msg += ': ' + err.error;
            } catch (_) {
                msg += ': Error inesperado del servidor (posiblemente HTML)';
            }
            alert(msg);
        }
    } catch (err) {
        console.error(err);
        alert('Error de conexión: ' + err.message);
    }
}
</script>

<div id="new-event-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4">
    <div class="bg-slate-800 p-6 rounded-2xl w-full max-w-md shadow-2xl border border-slate-700 max-h-[90vh] overflow-y-auto custom-scroll">
        <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <i class="ph ph-calendar-plus text-blue-400"></i> Nuevo Evento
        </h3>
        <form action="/calendario/eventos" method="POST" class="space-y-4">
            <input type="hidden" name="month" value="<%= month %>">
            <input type="hidden" name="year" value="<%= year %>">
            <div>
                <label class="block text-slate-400 text-sm mb-2">Título</label>
                <input type="text" name="titulo" required class="w-full bg-slate-900 border border-slate-700 rounded p-2 text-white focus:outline-none focus:border-blue-500">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-slate-400 text-sm mb-2">Fecha</label>
                    <input type="date" name="fecha" required class="w-full bg-slate-900 border border-slate-700 rounded p-2 text-white focus:outline-none focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-slate-400 text-sm mb-2">Tipo de evento</label>
                    <select name="tipo" class="w-full bg-slate-900 border border-slate-700 rounded p-2 text-white text-sm focus:outline-none focus:border-blue-500">
                        <option value="">General</option>
                        <option value="ticket">Ticket</option>
                        <option value="mantencion">Mantención</option>
                        <option value="otro">Otro</option>
                    </select>
                </div>
            </div>
